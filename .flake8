[flake8]
max-line-length = 120
; W291 	Trailing whitespace
; E203 	Whitespace before ':'
; W503 	Line break occurred before a binary operator
; E231	Missing whitespace after ':' — incorrectly fires on colons inside f-string
;       expressions (e.g. f"{HOST}:{PORT}"), which is a known flake8 tokeniser bug
ignore = W291, E203, W503, E231
exclude =
    __pycache__
    node_modules
    .venv
    .direnv

; vim: ft=dosini
